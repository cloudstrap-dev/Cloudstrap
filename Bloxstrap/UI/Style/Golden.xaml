<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="#0D0C0B"/>
    <SolidColorBrush x:Key="SecondaryBackgroundBrush" Color="#171512"/>
    <SolidColorBrush x:Key="TertiaryBackgroundBrush" Color="#221F1A"/>
    
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="#FFF9F0"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="#D4C4A8"/>
    <SolidColorBrush x:Key="TextEditorLinkBrush" Color="#FFD700"/>

    <SolidColorBrush x:Key="AccentBrush" Color="#C5A059"/>
    <SolidColorBrush x:Key="AccentBrushSecondary" Color="#E5C17A"/>
    
    <Style TargetType="Button">
        <Setter Property="Background" Value="#1F1C18" />
        <Setter Property="BorderBrush" Value="#443E33" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#C5A059" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>